# ==========================================
# SEAPEDIA Application Configuration
# ==========================================

# ------------------------------------------
# APPLICATION GENERAL SETTINGS
# ------------------------------------------
# APP_NAME: The name of the application, used in emails and UI headers.
APP_NAME=SEAPEDIA
# APP_ENV: Environment type (local, production, staging).
APP_ENV=local
# APP_KEY: Laravel application key for encryption. Generated via `php artisan key:generate`.
APP_KEY=
# APP_DEBUG: Set to true for local development to see errors. Must be false in production.
APP_DEBUG=true
# APP_TIMEZONE: Default timezone for the application.
APP_TIMEZONE=Asia/Jakarta
# APP_URL: The public URL of the application.
APP_URL=http://localhost:8000

# Locale configurations
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US
APP_MAINTENANCE_DRIVER=file

# ------------------------------------------
# ADMIN CREDENTIALS FOR SEEDING
# ------------------------------------------
# Used by database seeders (AdminSeeder) to create the default Admin account.
ADMIN_EMAIL=admin@seapedia.demo
ADMIN_PASSWORD=password123

# ------------------------------------------
# DATABASE CONNECTION
# ------------------------------------------
# Settings to connect to the database. Example shown is for MySQL via sail/docker.
DB_CONNECTION=postgresql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=seapedia
DB_USERNAME=
DB_PASSWORD=

# ------------------------------------------
# CACHE, SESSION & QUEUES
# ------------------------------------------
# SESSION_DRIVER: Session storage (file, cookie, database, apc, memcached, redis, dynamodb, array)
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
CACHE_STORE=file

# ------------------------------------------
# REDIS (Optional for Queue & Cache)
# ------------------------------------------
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=
REDIS_PORT=6379

# ------------------------------------------
# LOCAL DEVELOPMENT DOCKER PORTS
# ------------------------------------------
APP_PORT=8000
VITE_PORT=5173

# ------------------------------------------
# MAIL CONFIGURATION
# ------------------------------------------
# Settings for sending emails (e.g. SMTP for sending verification/forgot password links).
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="no-reply@seapedia.test"
MAIL_FROM_NAME="${APP_NAME}"

# ------------------------------------------
# FRONTEND VARIABLES
# ------------------------------------------
# Variables injected into the frontend, mapped from APP_NAME
VITE_APP_NAME="${APP_NAME}"
